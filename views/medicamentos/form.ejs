<%- include('../partials/header') %>

<section class="page-header">
  <h1><%= accion === 'crear' ? '➕ Nuevo medicamento' : '✏️ Editar medicamento' %></h1>
  <a href="/medicamentos" class="btn btn-secondary">← Volver</a>
</section>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="form-card">
  <form action="<%= accion === 'crear' ? '/medicamentos' : '/medicamentos/editar/' + medicamento.id %>" method="POST">
    <div class="form-grid">
      <div class="form-group form-full">
        <label for="nombre">Nombre del medicamento *</label>
        <input type="text" id="nombre" name="nombre"
               value="<%= medicamento ? medicamento.nombre : '' %>" required>
      </div>
      <div class="form-group form-full">
        <label for="descripcion">Descripción</label>
        <textarea id="descripcion" name="descripcion" rows="2"><%= medicamento ? medicamento.descripcion : '' %></textarea>
      </div>
      <div class="form-group">
        <label for="categoria">Categoría</label>
        <input type="text" id="categoria" name="categoria"
               value="<%= medicamento ? medicamento.categoria : '' %>"
               placeholder="Ej: Analgésico, Antibiótico...">
      </div>
      <div class="form-group">
        <label for="precio">Precio (COP) *</label>
        <input type="number" id="precio" name="precio" min="0" step="0.01"
               value="<%= medicamento ? medicamento.precio : '' %>" required>
      </div>
      <div class="form-group">
        <label for="stock">Stock inicial</label>
        <input type="number" id="stock" name="stock" min="0"
               value="<%= medicamento ? medicamento.stock : 0 %>">
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= accion === 'crear' ? 'Guardar medicamento' : 'Actualizar medicamento' %>
      </button>
      <a href="/medicamentos" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
