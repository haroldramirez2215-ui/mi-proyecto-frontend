<%- include('../partials/header') %>

<section class="page-header">
  <h1><%= accion === 'crear' ? '➕ Nuevo cliente' : '✏️ Editar cliente' %></h1>
  <a href="/clientes" class="btn btn-secondary">← Volver</a>
</section>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="form-card">
  <form action="<%= accion === 'crear' ? '/clientes' : '/clientes/editar/' + cliente.id %>" method="POST">
    <div class="form-grid">
      <div class="form-group">
        <label for="nombre">Nombre *</label>
        <input type="text" id="nombre" name="nombre"
               value="<%= cliente ? cliente.nombre : '' %>" required>
      </div>
      <div class="form-group">
        <label for="apellido">Apellido *</label>
        <input type="text" id="apellido" name="apellido"
               value="<%= cliente ? cliente.apellido : '' %>" required>
      </div>
      <div class="form-group">
        <label for="documento">Documento</label>
        <input type="text" id="documento" name="documento"
               value="<%= cliente ? cliente.documento : '' %>">
      </div>
      <div class="form-group">
        <label for="telefono">Teléfono</label>
        <input type="text" id="telefono" name="telefono"
               value="<%= cliente ? cliente.telefono : '' %>">
      </div>
      <div class="form-group form-full">
        <label for="email">Email</label>
        <input type="email" id="email" name="email"
               value="<%= cliente ? cliente.email : '' %>">
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= accion === 'crear' ? 'Guardar cliente' : 'Actualizar cliente' %>
      </button>
      <a href="/clientes" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
