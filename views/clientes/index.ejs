<%- include('../partials/header') %>

<section class="page-header">
  <h1>👥 Clientes</h1>
  <a href="/clientes/nuevo" class="btn btn-primary">+ Nuevo cliente</a>
</section>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<% if (clientes.length === 0) { %>
  <div class="empty-state">
    <p>No hay clientes registrados aún.</p>
    <a href="/clientes/nuevo" class="btn btn-primary">Registrar primer cliente</a>
  </div>
<% } else { %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Nombre</th>
          <th>Apellido</th>
          <th>Documento</th>
          <th>Teléfono</th>
          <th>Email</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% clientes.forEach(c => { %>
        <tr>
          <td><%= c.id %></td>
          <td><%= c.nombre %></td>
          <td><%= c.apellido %></td>
          <td><%= c.documento %></td>
          <td><%= c.telefono %></td>
          <td><%= c.email %></td>
          <td class="acciones">
            <a href="/clientes/editar/<%= c.id %>" class="btn btn-edit">✏️ Editar</a>
            <form action="/clientes/eliminar/<%= c.id %>" method="POST"
                  onsubmit="return confirm('¿Eliminar a <%= c.nombre %>?')">
              <button class="btn btn-delete">🗑️ Eliminar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
